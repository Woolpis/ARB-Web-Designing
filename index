<script>
// before/after slider
const ba = document.getElementById('ba');
const range = document.getElementById('baRange');
const badge = document.getElementById('baBadge');
function setCut(v){
  ba.style.setProperty('--cut', v + '%');
  const dopo = v < 50; // il sito nuovo copre la maggior parte del riquadro
  badge.textContent = dopo ? 'DOPO' : 'PRIMA';
  badge.classList.toggle('dopo', dopo);
}
range.addEventListener('input', e => setCut(parseFloat(e.target.value)));
setCut(50);

// scroll reveal
const io = new IntersectionObserver(es => {
  es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
}, { threshold: 0.12 });
document.querySelectorAll('.rv').forEach(el => io.observe(el));

// form: se Formspree non è configurato, fallback a mailto precompilata
const form = document.getElementById('reqForm');
form.addEventListener('submit', function (e) {
  if (form.action.includes('TUO-ID')) {
    e.preventDefault();
    const d = new FormData(form);
    const body = encodeURIComponent(
      `Nome: ${d.get('nome')}\nAzienda: ${d.get('azienda')}\nEmail: ${d.get('email')}\nTelefono: ${d.get('telefono')}\nRichiesta: ${d.get('tipo')}\nSito attuale: ${d.get('sito_attuale')}\n\n${d.get('messaggio')}`
    );
    window.location.href = `mailto:aleresminib@gmail.com?subject=${encodeURIComponent('Richiesta preventivo sito web — ' + (d.get('azienda') || d.get('nome')))}&body=${body}`;
    document.getElementById('okMsg').style.display = 'block';
  }
});
</script>
